# PHASE 1 (current): nothing here is required — all data lives in the
# browser's localStorage. This file documents what Phase 2 will need
# once lib/data.js is switched from localStorage to a real backend.

# --- Option A: Firebase ---
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Option B: PostgreSQL (e.g. Vercel Postgres / Supabase / Neon) ---
# DATABASE_URL=postgresql://user:password@host:5432/marathon_saas

# --- Auth (Phase 2, replaces the demo role-switcher) ---
# AUTH_SECRET=
# NEXTAUTH_URL=http://localhost:3000
